{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "C/C++: Prepare Output Directory",
            "type": "process",
            "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "args": [
                "-NoProfile",
                "-Command",
                "New-Item -ItemType Directory -Path \"${workspaceFolder}\\build\\${relativeFileDirname}\" -Force | Out-Null"
            ],
            "problemMatcher": []
        },
        {
            "label": "C/C++: Build Current File",
            "type": "process",
            "command": "C:\\Users\\86189\\AppData\\Local\\Microsoft\\WinGet\\Packages\\BrechtSanders.WinLibs.POSIX.UCRT_Microsoft.Winget.Source_8wekyb3d8bbwe\\mingw64\\bin\\g++.exe",
            "args": [
                "-Wall",
                "-Wextra",
                "-g3",
                "-std=gnu++17",
                "-finput-charset=UTF-8",
                "-fexec-charset=UTF-8",
                "${file}",
                "-o",
                "${workspaceFolder}\\build\\${relativeFileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "env": {
                    "PATH": "C:\\Users\\86189\\AppData\\Local\\Microsoft\\WinGet\\Packages\\BrechtSanders.WinLibs.POSIX.UCRT_Microsoft.Winget.Source_8wekyb3d8bbwe\\mingw64\\bin;${env:PATH}"
                }
            },
            "dependsOn": "C/C++: Prepare Output Directory",
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "problemMatcher": {
                "owner": "cpp",
                "fileLocation": "absolute",
                "pattern": {
                    "regexp": "^(.*):(\\d+):(\\d+):\\s+(warning|error):\\s+(.*)$",
                    "file": 1,
                    "line": 2,
                    "column": 3,
                    "severity": 4,
                    "message": 5
                }
            },
            "detail": "Compile only the current .cpp file"
        },
        {
            "label": "C/C++: Run Current File",
            "type": "process",
            "command": "C:\\Windows\\System32\\WindowsPowerShell\\v1.0\\powershell.exe",
            "args": [
                "-NoProfile",
                "-Command",
                "Start-Process -FilePath 'C:\\Windows\\System32\\cmd.exe' -ArgumentList '/k', '\"${workspaceFolder}\\build\\${relativeFileDirname}\\${fileBasenameNoExtension}.exe\"' -WorkingDirectory '${workspaceFolder}'"
            ],
            "options": {
                "env": {
                    "PATH": "C:\\Users\\86189\\AppData\\Local\\Microsoft\\WinGet\\Packages\\BrechtSanders.WinLibs.POSIX.UCRT_Microsoft.Winget.Source_8wekyb3d8bbwe\\mingw64\\bin;${env:PATH}"
                }
            },
            "group": "test",
            "problemMatcher": [],
            "dependsOn": "C/C++: Build Current File",
            "presentation": {
                "reveal": "never",
                "focus": false
            },
            "detail": "Run only the current .cpp file in a separate console window"
        },
        {
            "type": "cppbuild",
            "label": "C/C++: g++.exe 生成活动文件",
            "command": "C:\\Users\\86189\\AppData\\Local\\Microsoft\\WinGet\\Packages\\BrechtSanders.WinLibs.POSIX.UCRT_Microsoft.Winget.Source_8wekyb3d8bbwe\\mingw64\\bin\\g++.exe",
            "args": [
                "-fdiagnostics-color=always",
                "-g",
                "${file}",
                "-o",
                "${fileDirname}\\${fileBasenameNoExtension}.exe"
            ],
            "options": {
                "cwd": "C:\\Users\\86189\\AppData\\Local\\Microsoft\\WinGet\\Packages\\BrechtSanders.WinLibs.POSIX.UCRT_Microsoft.Winget.Source_8wekyb3d8bbwe\\mingw64\\bin"
            },
            "problemMatcher": [
                "$gcc"
            ],
            "group": {
                "kind": "build",
                "isDefault": false
            },
            "detail": "调试器生成的任务。"
        }
    ]
}
